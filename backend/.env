# ── Base de datos ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/gastos_app"

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET="cambia_esto_por_un_string_largo_y_aleatorio_min_32_chars"
JWT_EXPIRES_IN="7d"

# ── Servidor ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ── Email (para alertas) ───────────────────────────────────
# Opción gratuita: crear cuenta en https://ethereal.email para desarrollo
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu@gmail.com"
SMTP_PASS="tu_app_password_de_gmail"
EMAIL_FROM="Control de Gastos <tu@gmail.com>"

# ── Firebase (notificaciones push - opcional fase 1) ───────
# Descarga serviceAccountKey.json desde Firebase Console
# FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
